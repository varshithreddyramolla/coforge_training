<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:p="http://www.springframework.org/schema/p"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

	<bean id="deliveryAddress1"
		class="com.coforge.model.DeliveryAddress">
		<property name="city" value="Yadadri"></property>
		<property name="state" value="Telangana"></property>
	</bean>

	<bean id="deliveryAddress2"
		class="com.coforge.model.DeliveryAddress">
		<property name="city" value="Rangareddy"></property>
		<property name="state" value="Telangana"></property>
	</bean>

	<bean id="customer1" class="com.coforge.model.Customer">
		<property name="customerId" value="111"></property>
		<property name="customerName" value="Ramesh"></property>
		<property name="emails">
			<list>  <!-- to pass list collection -->
				<value>ramesh1@gmail.com</value>
				<value>ramesh2@gmail.com</value>
			</list>
		</property>
		<property name="delivaryAddress">
			<list> <!--  to pass list collection of another Object -->
				<ref bean="deliveryAddress1"></ref>
				<ref bean="deliveryAddress2"></ref>
			</list>
		</property>
	</bean>
</beans>